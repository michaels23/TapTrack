@page "/"
@using TapTrack.Shared.Services
@inject IFormFactor FormFactor

<PageTitle>Home</PageTitle>

<h1>Tap Track</h1>

Welcome to this app running on <em>@factor</em> using <em>@platform</em>.
<p role="status">Current timestamp: @timeStamp</p>
<p>Last clicked button: @lastClicked</p>

<button class="btn btn-primary" @onclick='() => Track("Accept")'>Accept</button>

@code {
    private string factor => FormFactor.GetFormFactor();
    private string platform => FormFactor.GetPlatform();

    private DateTime timeStamp = DateTime.Now;
    private string? lastClicked;

    private void Track(string text)
    {
        lastClicked = text;
        timeStamp = DateTime.Now;
    }
}
