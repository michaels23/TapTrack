@page "/"
@using TapTrack.Shared.Services
@using System.Net.Http.Json
@inject HttpClient Http
@inject IFormFactor FormFactor

<PageTitle>Home</PageTitle>

<h3>Home</h3>

@if (isLoading)
{
    <p>Loading...</p>
}
else if (!string.IsNullOrEmpty(loadError))
{
    <p class="text-danger">@loadError</p>
}
else
{
    <div class="btn-group" role="group" aria-label="Track buttons">
        @foreach (var b in Buttons)
        {
            <button class="btn btn-@b.Color" @onclick="() => Track(b.Label)">@b.Label</button>
        }
    </div>
}

@code {
    record ButtonDef(string Label, string Color);

    private ButtonDef[] Buttons = Array.Empty<ButtonDef>();
    private bool isLoading = true;
    private string? loadError;

    protected override async Task OnInitializedAsync()
    {
        var defaultButtons = new[]
        {
            new ButtonDef("Acceptance", "Green"),
            new ButtonDef("Resistance", "Red")
        };
        try
        {
            // Adjust the endpoint as needed for your API
            Buttons = await Http.GetFromJsonAsync<ButtonDef[]>("/api/buttons") ?? defaultButtons;
        }
        catch (Exception ex)
        {
            loadError = $"Failed to load buttons: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string factor => FormFactor.GetFormFactor();
    private string platform => FormFactor.GetPlatform();

    private DateTime timeStamp = DateTime.Now;
    private string? lastClicked;

    private void Track(string text)
    {
        lastClicked = text;
        timeStamp = DateTime.Now;
    }
}